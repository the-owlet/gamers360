generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  email         String    @unique
  passwordHash  String
  fullName      String    @default("")
  avatarUrl     String    @default("🎮")
  level         Int       @default(1)
  xp            Int       @default(0)
  totalGamesPlayed Int    @default(0)
  totalWins     Int       @default(0)
  loginStreak   Int       @default(0)
  lastLoginDate String?
  lastRewardDate String?
  referralCode  String    @unique @default(cuid())
  referredBy    String?
  referralCount Int       @default(0)
  lastGameAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  wallet        Wallet?
  gameHistories GameHistory[]
  withdrawals   Withdrawal[]
  achievements  UserAchievement[]
  dailyChallenges UserDailyChallenge[]
  bankAccounts  BankAccount[]
  challengesSent     MultiplayerMatch[] @relation("challenger")
  challengesReceived MultiplayerMatch[] @relation("opponent")
}

model BankAccount {
  id            String   @id @default(cuid())
  userId        String
  bankName      String
  accountNumber String
  accountName   String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  totalEarned Int    @default(0)
  totalWithdrawn Int @default(0)
  currency  String   @default("NGN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GameHistory {
  id        String   @id @default(cuid())
  userId    String
  gameSlug  String
  score     Int      @default(0)
  pointsEarned Int   @default(0)
  betAmount Int      @default(0)
  won       Boolean  @default(false)
  playedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([gameSlug])
}

model Withdrawal {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  currency    String   @default("NGN")
  method      String
  accountDetails String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  processedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserAchievement {
  id          String   @id @default(cuid())
  userId      String
  achievementId String
  unlockedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

model GameSession {
  id        String   @id @default(cuid())
  userId    String
  gameSlug  String
  token     String   @unique
  seed      Int
  won       Boolean
  betAmount Int      @default(0)
  completed Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model MultiplayerMatch {
  id             String   @id @default(cuid())
  gameSlug       String
  betAmount      Int
  seed           Int

  challengerId   String
  challengerScore Int?
  challengerDone Boolean  @default(false)

  opponentId     String?
  opponentScore  Int?
  opponentDone   Boolean  @default(false)

  winnerId       String?
  status         String   @default("waiting") // waiting, active, completed, cancelled, expired
  payout         Int      @default(0)

  expiresAt      DateTime
  createdAt      DateTime @default(now())
  completedAt    DateTime?

  challenger     User     @relation("challenger", fields: [challengerId], references: [id], onDelete: Cascade)
  opponent       User?    @relation("opponent", fields: [opponentId], references: [id], onDelete: SetNull)

  @@index([challengerId])
  @@index([opponentId])
  @@index([status])
  @@index([gameSlug, status])
}

model UserDailyChallenge {
  id          String   @id @default(cuid())
  userId      String
  challengeId String
  date        String
  progress    Int      @default(0)
  target      Int
  completed   Boolean  @default(false)
  claimed     Boolean  @default(false)
  reward      Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId, date])
  @@index([userId, date])
}
